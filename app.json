{
  "expo": {
    "name": "DoToR",
    "slug": "dotor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "dotor",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.dotor.app",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyD5ecLfVJ9t15XhnEQgMjyJC1YbOPJIXEg"
        }
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dotor.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "DoToR needs your location to show technician tracking",
        "NSCameraUsageDescription": "DoToR needs camera to upload photos",
        "NSPhotoLibraryUsageDescription": "DoToR needs gallery access to upload photos"
      },
      "config": {
        "googleMapsApiKey": "AIzaSyD5ecLfVJ9t15XhnEQgMjyJC1YbOPJIXEg"
      }
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-image-picker",
      [
        "expo-notifications",
        {
          "color": "#FF6B00",
          "sounds": []
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b18f7f63-5dd7-4fe2-8446-2574761e1476"
      }
    },
    "owner": "dotor"
  }
}
