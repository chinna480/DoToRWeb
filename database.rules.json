{
  "rules": {
    ".read": false,
    ".write": false,
    "orders": {
      ".read": true,
      ".write": true,
      ".indexOn": ["customerPhone", "status", "techPhone", "createdAt"],
      "$orderId": {
        ".validate": "newData.hasChildren(['customerName', 'customerPhone', 'status'])",
        "customerName": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
        "customerPhone": { ".validate": "newData.isString() && newData.val().length >= 10" },
        "customerPushToken": { ".validate": "newData.isString()" },
        "status": {
          ".validate": "newData.isString() && (newData.val() === 'pending' || newData.val() === 'accepted' || newData.val() === 'completed' || newData.val() === 'rejected')"
        },
        "brand": { ".validate": "newData.isString() && newData.val().length <= 100" },
        "repair": { ".validate": "newData.isString() && newData.val().length <= 200" },
        "modelName": { ".validate": "newData.isString() && newData.val().length <= 100" },
        "description": { ".validate": "newData.isString() && newData.val().length <= 2000" },
        "location": { ".validate": "newData.isString() && newData.val().length <= 500" },
        "pincode": { ".validate": "newData.isString() && newData.val().length <= 10" },
        "time": { ".validate": "newData.isString()" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "images": { ".validate": "newData.isString() || newData.hasChildren()" },
        "techPhone": { ".validate": "newData.isString() && newData.val().length >= 10" },
        "techName": { ".validate": "newData.isString() && newData.val().length <= 100" },
        "completedTime": { ".validate": "newData.isNumber()" },
        "isAppointment": { ".validate": "newData.isBoolean()" },
        "appointmentTime": { ".validate": "newData.isNumber()" },
        "date": { ".validate": "newData.isString()" },
        "dateLabel": { ".validate": "newData.isString()" },
        "timeSlot": { ".validate": "newData.isString()" },
        "reminderSent": { ".validate": "newData.isBoolean()" },
        "custLat": { ".validate": "newData.isNumber()" },
        "custLng": { ".validate": "newData.isNumber()" },
        "custLocation": {
          "$loc": {
            "lat": { ".validate": "newData.isNumber()" },
            "lng": { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        },
        "techLocation": {
          "$loc": {
            "lat": { ".validate": "newData.isNumber()" },
            "lng": { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        },
        "$other": { ".validate": true }
      }
    },
    "chats": {
      "$orderId": {
        ".read": true,
        ".write": true,
        "messages": {
          "$messageId": {
            ".validate": "newData.hasChildren(['text', 'senderRole', 'timestamp'])",
            "text": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 1000" },
            "senderRole": { ".validate": "newData.isString() && (newData.val() === 'cust' || newData.val() === 'tech')" },
            "senderName": { ".validate": "newData.isString() && newData.val().length <= 100" },
            "timestamp": { ".validate": "newData.isNumber()" },
            "read": { ".validate": "newData.isBoolean()" },
            "$other": { ".validate": false }
          }
        },
        "metadata": {
          ".validate": "newData.hasChildren(['lastMessage', 'lastSender', 'lastTime'])",
          "lastMessage": { ".validate": "newData.isString()" },
          "lastSender": { ".validate": "newData.isString()" },
          "lastTime": { ".validate": "newData.isNumber()" },
          "customerName": { ".validate": "newData.isString()" },
          "techName": { ".validate": "newData.isString()" },
          "$other": { ".validate": true }
        }
      }
    },
    "users": {
      "$phone": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['name', 'phone'])",
        "name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
        "phone": { ".validate": "newData.isString() && newData.val().length >= 10" },
        "pushToken": { ".validate": "newData.isString()" },
        "location": { ".validate": "newData.isString() && newData.val().length <= 500" },
        "pincode": { ".validate": "newData.isString() && newData.val().length <= 10" },
        "email": { ".validate": "newData.isString()" },
        "$other": { ".validate": true }
      }
    },
    "techs": {
      "$phone": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['name', 'phone'])",
        "name": { ".validate": "newData.isString()" },
        "phone": { ".validate": "newData.isString()" },
        "pushToken": { ".validate": "newData.isString()" },
        "location": { ".validate": "newData.isString()" },
        "pincode": { ".validate": "newData.isString()" },
        "$other": { ".validate": true }
      }
    },
    "techUsers": {
      "$phone": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['name', 'phone'])",
        "name": { ".validate": "newData.isString()" },
        "phone": { ".validate": "newData.isString()" },
        "pushToken": { ".validate": "newData.isString()" },
        "location": { ".validate": "newData.isString()" },
        "pincode": { ".validate": "newData.isString()" },
        "photo": { ".validate": "newData.isString()" },
        "$other": { ".validate": true }
      }
    },
    "techsOnline": {
      ".read": true,
      "$phone": {
        ".write": true,
        ".validate": "newData.hasChildren(['lat', 'lng', 'lastSeen'])",
        "lat": { ".validate": "newData.isNumber()" },
        "lng": { ".validate": "newData.isNumber()" },
        "name": { ".validate": "newData.isString()" },
        "lastSeen": { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    },
    "pushTokens": {
      "$phone": {
        ".read": true,
        ".write": true
      }
    },
    "reviews": {
      ".read": true,
      "$reviewId": {
        ".write": true,
        ".validate": "newData.hasChildren(['customerName', 'rating'])",
        "customerName": { ".validate": "newData.isString() && newData.val().length > 0" },
        "rating": { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 5" },
        "comment": { ".validate": "newData.isString() && newData.val().length <= 2000" },
        "time": { ".validate": "newData.isString()" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    },
    "techRatings": {
      "$phone": {
        ".read": true,
        ".write": true
      }
    },
    "areaAssignments": {
      "$area": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['name', 'phone'])",
        "name": { ".validate": "newData.isString()" },
        "phone": { ".validate": "newData.isString()" },
        "location": { ".validate": "newData.isString()" },
        "$other": { ".validate": false }
      }
    },
    "techInfo": { ".read": true, ".write": true },
    "custLocation": { ".read": true, ".write": true }
  }
}