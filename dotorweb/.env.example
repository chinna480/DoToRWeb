# ── DoToR Web - Backend Environment Variables ─────────────────
# Copy this file to .env and fill in the values.
# These are used by the Vercel serverless functions (api/*.js).

# Required for AI-powered Aadhar verification via the backend proxy.
# Get a key at: https://console.anthropic.com/
# The key stays server-side — never exposed to the app.
ANTHROPIC_API_KEY=
